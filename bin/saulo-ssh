#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="$HOME/.config/saulo-ssh"
CONFIG_FILE="$CONFIG_DIR/config"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

load_config() {
  if [[ ! -f "$CONFIG_FILE" ]]; then
    mkdir -p "$CONFIG_DIR"
    echo "USER=" > "$CONFIG_FILE"
    echo "IP=" >> "$CONFIG_FILE"
    echo "PORTS=" >> "$CONFIG_FILE"
  fi
  source "$CONFIG_FILE"
}

save_config() {
  cat > "$CONFIG_FILE" <<EOF
USER=$USER
IP=$IP
PORTS=$PORTS
EOF
}

check_host() {
  local ip="$1"
  if ping -c 1 -W 2 "$ip" &>/dev/null; then
    return 0
  else
    return 1
  fi
}

is_port_ssh_forwarded() {
  local port="$1"
  # Check if an existing SSH process is listening on this port
  lsof -iTCP:"$port" -sTCP:LISTEN -nP 2>/dev/null | grep -q ssh
}

build_port_flags() {
  local ports="$1"
  local flags=""
  IFS=',' read -ra PORT_ARRAY <<< "$ports"
  for port in "${PORT_ARRAY[@]}"; do
    port=$(echo "$port" | xargs) # trim whitespace
    [[ -z "$port" ]] && continue
    if is_port_ssh_forwarded "$port"; then
      printf "${YELLOW}⊘ Port $port already forwarded by existing SSH tunnel, skipping${NC}\n" >&2
    else
      flags="$flags -L $port:localhost:$port"
    fi
  done
  echo "$flags"
}

cmd_connect() {
  load_config

  # Check if IP is set and reachable
  if [[ -n "$IP" ]]; then
    printf "${CYAN}Checking if ${BOLD}$IP${NC}${CYAN} is reachable...${NC}\n"
    if check_host "$IP"; then
      printf "${GREEN}✓ Host is reachable${NC}\n"
    else
      printf "${RED}✗ Host $IP is not reachable${NC}\n"
      read -rp "Enter new IP (or Ctrl+C to cancel): " NEW_IP
      IP="$NEW_IP"
      save_config
    fi
  else
    read -rp "Enter SSH host IP: " IP
    save_config
  fi

  if [[ -z "$USER" ]]; then
    read -rp "Enter SSH user: " USER
    save_config
  fi

  # Check which ports need forwarding
  printf "\n"
  local port_flags
  port_flags=$(build_port_flags "$PORTS")

  printf "\n${BOLD}Connecting to ${CYAN}$USER@$IP${NC}\n"

  # Show which ports will actually be forwarded
  if [[ -n "$port_flags" ]]; then
    printf "${YELLOW}Forwarding ports:${NC}"
    echo "$port_flags" | grep -oE '[0-9]+:localhost:[0-9]+' | while IFS= read -r mapping; do
      local p="${mapping%%:*}"
      printf " ${GREEN}$p${NC}"
    done
    printf "\n"
  fi
  printf "\n"

  # shellcheck disable=SC2086
  ssh $port_flags "$USER@$IP"
}

cmd_ls() {
  load_config

  printf "${BOLD}${CYAN}── Configuration ──${NC}\n"
  printf "  User: ${BOLD}$USER${NC}\n"
  printf "  Host: ${BOLD}$IP${NC}\n"
  if [[ -n "$PORTS" ]]; then
    printf "  Configured ports: "
    IFS=',' read -ra PORT_ARRAY <<< "$PORTS"
    for port in "${PORT_ARRAY[@]}"; do
      port=$(echo "$port" | xargs)
      [[ -z "$port" ]] && continue
      printf "${GREEN}$port${NC} "
    done
    printf "\n"
  else
    printf "  Configured ports: ${YELLOW}none${NC}\n"
  fi

  printf "\n${BOLD}${CYAN}── Active SSH Tunnels ──${NC}\n"
  local tunnels
  tunnels=$(ps aux | grep "ssh.*-L" | grep -v grep || true)
  if [[ -z "$tunnels" ]]; then
    printf "  ${YELLOW}No active SSH tunnels found${NC}\n"
  else
    echo "$tunnels" | while IFS= read -r line; do
      # Extract forwarded ports from the command
      local ports_found
      ports_found=$(echo "$line" | grep -oE '\-L [0-9]+:localhost:[0-9]+' | sed 's/-L /  ↳ /')
      local target
      target=$(echo "$line" | grep -oE '[a-zA-Z0-9_]+@[0-9.]+' | head -1)
      if [[ -n "$target" ]]; then
        printf "  ${BOLD}$target${NC}\n"
        if [[ -n "$ports_found" ]]; then
          echo "$ports_found" | while IFS= read -r pline; do
            printf "  ${GREEN}$pline${NC}\n"
          done
        fi
      fi
    done
  fi

  printf "\n${BOLD}${CYAN}── Listening Ports ──${NC}\n"
  local listening
  listening=$(lsof -iTCP -sTCP:LISTEN -nP 2>/dev/null | grep ssh || true)
  if [[ -z "$listening" ]]; then
    printf "  ${YELLOW}No SSH-forwarded ports currently listening${NC}\n"
  else
    echo "$listening" | awk '{printf "  %-8s %s\n", $1, $9}'
  fi
}

cmd_add() {
  local port="$1"
  load_config

  if [[ -z "$PORTS" ]]; then
    PORTS="$port"
  else
    # Check if already exists
    IFS=',' read -ra PORT_ARRAY <<< "$PORTS"
    for existing in "${PORT_ARRAY[@]}"; do
      existing=$(echo "$existing" | xargs)
      if [[ "$existing" == "$port" ]]; then
        printf "${YELLOW}Port $port is already configured${NC}\n"
        return
      fi
    done
    PORTS="$PORTS,$port"
  fi

  save_config
  printf "${GREEN}✓ Added port $port${NC}\n"
}

cmd_rm() {
  local port="$1"
  load_config

  local new_ports=""
  IFS=',' read -ra PORT_ARRAY <<< "$PORTS"
  for existing in "${PORT_ARRAY[@]}"; do
    existing=$(echo "$existing" | xargs)
    if [[ "$existing" != "$port" ]]; then
      if [[ -z "$new_ports" ]]; then
        new_ports="$existing"
      else
        new_ports="$new_ports,$existing"
      fi
    fi
  done

  if [[ "$new_ports" == "$PORTS" ]]; then
    printf "${YELLOW}Port $port is not configured${NC}\n"
    return
  fi

  PORTS="$new_ports"
  save_config
  printf "${GREEN}✓ Removed port $port${NC}\n"
}

cmd_ip() {
  local new_ip="$1"
  load_config
  IP="$new_ip"
  save_config
  printf "${GREEN}✓ Updated IP to $new_ip${NC}\n"
}

cmd_dl() {
  local remote_path="$1"
  local local_path="${2:-$HOME/Downloads}"
  load_config

  if [[ -z "$USER" || -z "$IP" ]]; then
    printf "${RED}✗ USER and IP must be configured. Run 'saulo-ssh' first.${NC}\n"
    exit 1
  fi

  printf "${BOLD}Downloading${NC} ${CYAN}$USER@$IP:$remote_path${NC}\n"
  printf "  → ${GREEN}$local_path${NC}\n\n"

  scp "$USER@$IP:$remote_path" "$local_path"
  printf "\n${GREEN}✓ Download complete${NC}\n"
}

cmd_help() {
  printf "${BOLD}saulo-ssh${NC} — SSH with port forwarding made easy\n\n"
  printf "${BOLD}Usage:${NC}\n"
  printf "  saulo-ssh                          Connect to the configured host\n"
  printf "  saulo-ssh ls                       List config and active tunnels\n"
  printf "  saulo-ssh add <port>               Add a port to forward\n"
  printf "  saulo-ssh rm <port>                Remove a forwarded port\n"
  printf "  saulo-ssh ip <ip>                  Update the host IP\n"
  printf "  saulo-ssh dl <remote> [local]      Download files via scp (default: ~/Downloads)\n"
  printf "  saulo-ssh help                     Show this help\n"
  printf "\n${BOLD}Config:${NC} $CONFIG_FILE\n"
}

# Main
case "${1:-}" in
  ls)       cmd_ls ;;
  add)      cmd_add "${2:?Usage: saulo-ssh add <port>}" ;;
  rm)       cmd_rm "${2:?Usage: saulo-ssh rm <port>}" ;;
  ip)       cmd_ip "${2:?Usage: saulo-ssh ip <new-ip>}" ;;
  help|-h|--help) cmd_help ;;
  "")       cmd_connect ;;
  dl)       cmd_dl "${2:?Usage: saulo-ssh dl <remote-path> [local-path]}" "${3:-}" ;;
  *)        printf "${RED}Unknown command: $1${NC}\n"; cmd_help; exit 1 ;;
esac
