bastion () {
  if [ -z "$1" ]
  then
          profile='default'
  elif [[ "dev" == "$1" ]]
  then
          profile='development'
  elif [[ "prod" == "$1" ]]
  then
          profile='production'
  else
          profile=$1
  fi
  set -x
  aws ssm start-session --target $(aws ssm describe-instance-information --filters '[{"Key": "tag:Name", "Values": ["BastionHost"]}]' --query "InstanceInformationList[*].InstanceId" --output text --profile $profile) --profile $profile
  set +x
}
