# name a tab, prefer all caps
function nametab() {
	echo -ne "\033]0;${1:-UNNAMED}\007"
}

# color a tab RGB
function colortab() {
	echo -e "\033]6;1;bg;red;brightness;${1:-255}\a \033]6;1;bg;green;brightness;${2:-255}\a \033]6;1;bg;blue;brightness;${3:-255}\a"
}

# start local procs in iTerm tabs
# Add worker2 through worker6 to procList if you're working on teams besides org 1.
function start_procs() {
	osascript -e '
		tell application "iTerm2"
			tell current window
				set t to current tab

				set procList to {"wds", "web", "worker", "worker1", "rpc", "go", "metrics", "grabber"}

				repeat with procName in procList
					create tab with default profile
					tell current session
						write text procName
					end tell
				end repeat

				tell t
					select
				end tell
			end tell
		end tell
	'
}

